---
const logoWhite = '/assets/logos/boss-baby-enterprise-logo.webp';
const year = new Date().getFullYear();
---

<footer class="bg-brand-dark text-gray-300 relative overflow-hidden">
  <!-- Gradient overlay (simulates original footer bg image) -->
  <div class="absolute inset-0 opacity-30" style="background: linear-gradient(135deg, #630985 0%, #212121 40%, #390542 100%);"></div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Logo & Description -->
      <div class="space-y-3">
        <img src={logoWhite} alt="BOSS Consult" class="h-12 w-auto" />
        <p class="text-sm text-brand-gray-lighter leading-relaxed">
          BOSS Consult comprises dedicated and ambitious individuals who are deeply invested in creating a positive impact on the world.
        </p>
      </div>

      <!-- Quick Links -->
      <div class="space-y-3">
        <h3 class="text-white font-semibold font-[family-name:var(--font-family-accent)] uppercase tracking-[2px]">Quick Links</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">Home</a></li>
          <li><a href="/about" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">About Us</a></li>
          <li><a href="/employers" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">Employers</a></li>
          <li><a href="/candidates" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">Candidates</a></li>
          <li><a href="/jobs" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">Jobs</a></li>
          <li><a href="/contact" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="space-y-3">
        <h3 class="text-white font-semibold font-[family-name:var(--font-family-accent)] uppercase tracking-[2px]">Contact Info</h3>
        <ul class="space-y-3">
          <li class="flex items-center gap-4">
            <span class="text-white">&#9742;</span>
            <a href="tel:+27632404447" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">+27 63 240 4447</a>
          </li>
          <li class="flex items-center gap-4">
            <span class="text-white">&#9993;</span>
            <a href="mailto:gaylene@bossenterprise.co.za" class="text-sm text-brand-gray-lighter hover:text-brand-accent-hover transition-colors">gaylene@bossenterprise.co.za</a>
          </li>
          <li class="flex items-center gap-4">
            <span class="text-white">&#9906;</span>
            <span class="text-sm text-brand-gray-lighter">Cape Town, Western Cape</span>
          </li>
        </ul>
      </div>

      <!-- Follow Us -->
      <div class="space-y-3">
        <h3 class="text-white font-semibold font-[family-name:var(--font-family-accent)] uppercase tracking-[2px]">Follow Us</h3>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/teambossbabe/" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center bg-brand-darker text-white hover:bg-brand-accent transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.076v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.028 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/boss-babe-enterprise/" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center bg-brand-darker text-white hover:bg-brand-accent transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.065 2.065zm1.782 13.019H3.555V9H3.569v11.452zm16.882-16.452c0 1.14-.925 2.063-2.065 2.063-1.14 0-2.063-.925-2.063-2.065 0-1.138.925-2.063 2.063-2.063 1.14 0 2.065.925 2.065 2.063z"/></svg>
          </a>
          <a href="https://www.instagram.com/boss_consultenterprise?igsh=dXcyMG45eHdndWht" target="_blank" rel="noopener noreferrer" class="w-8 h-8 flex items-center justify-center bg-brand-darker text-white hover:bg-brand-accent transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.645-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358-2.618 6.78-6.98 6.98C8.668 23.986 8.259 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.98-6.98.058-1.28.072-1.689.072-3.948 0-3.259-.014-3.668-.072-4.948-.2-4.358-2.618-6.78-6.98-6.98C15.668.014 15.259 0 12 0z"/></svg>
          </a>
        </div>
        <p class="text-xs text-brand-gray">&copy; {year} BOSS Consult. All rights reserved.</p>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="relative border-t border-brand-gray/30 py-4 text-center">
    <p class="text-xs text-brand-gray">
      Powered by <a href="https://fully-booked.co.za" class="text-brand-accent hover:text-brand-accent-light transition-colors">Fully-Booked</a>
      | <a href="/privacy-policy" class="text-brand-accent hover:text-brand-accent-light transition-colors">Privacy Policy</a>
    </p>
  </div>
</footer>