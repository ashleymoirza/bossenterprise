nt px-6 py-3.5 font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-brand-dark hover:bg-brand-dark hover:text-white rounded-lg transition duration-300 cursor-pointer">
Send Message
</button> </form> </div> <div> <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark mb-8">Contact Information</h2> <div class="space-y-6"> <div class="flex items-start"> <div class="flex-shrink-0 w-10 h-10 bg-brand-accent/10 rounded-full flex items-center justify-center"><span class="text-brand-accent text-lg font-bold">P</span></div> <div class="ml-4"> <h3 class="text-sm font-semibold text-brand-dark uppercase tracking-wider">Phone</h3> <a href="tel:+27632404447" class="text-brand-accent hover:text-brand-accent-light transition text-lg font-medium">+27 63 240 4447</a> </div> </div> <div class="flex items-start"> <div class="flex-shrink-0 w-10 h-10 bg-brand-accent/10 rounded-full flex items-center justify-center"><span class="text-brand-accent text-lg font-bold">E</span></div> <div class="ml-4"> <h3 class="text-sm font-semibold text-brand-dark uppercase tracking-wider">Email</h3> <a href="mailto:gaylene@bossenterprise.co.za" class="text-brand-accent hover:text-brand-accent-light transition text-lg font-medium">gaylene@bossenterprise.co.za</a> </div> </div> <div class="flex items-start"> <div class="flex-shrink-0 w-10 h-10 bg-brand-accent/10 rounded-full flex items-center justify-center"><span class="text-brand-accent text-lg font-bold">L</span></div> <div class="ml-4"> <h3 class="text-sm font-semibold text-brand-dark uppercase tracking-wider">Location</h3> <p class="text-brand-gray text-lg">Cape Town, Western Cape</p> </div> </div> </div> <div class="mt-12 pt-8 border-t border-gray-200"> <h3 class="text-sm font-semibold text-brand-dark uppercase tracking-wider mb-6">Follow Us</h3> <div class="space-y-4"> <a href="https://www.facebook.com/teambossbabe/" target="_blank" class="flex items-center text-brand-gray hover:text-brand-accent transition group"> <svg class="w-5 h-5 mr-3" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.076v-3.47h3.047V9.43c0-3.007 1.