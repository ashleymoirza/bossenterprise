---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="BOSS Consult - Tech Recruitment Agency | Data Science &amp; Development Talent South Africa"
  description="We're not just recruiters — we're your growth partners. BOSS Consult specialises in placing high-impact tech talent across Data Science, Development, and Design. No upfront fees. Based in Cape Town."
>

  <!-- HERO SECTION (original: bg #3F2F42 + bg image + black overlay) -->
  <section class="relative overflow-hidden bg-brand-hero pt-24 pb-16 md:pb-24 bg-cover bg-center" style="background-image: url('/assets/logos/hero-image.webp');">
    <div class="absolute inset-0 bg-black/40"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-8 md:grid-cols-2">
        <div class="order-2 md:order-1 text-center md:text-left">
          <h1 class="text-white">
            Need Skilled Tech Talent<br class="hidden sm:block">
            <span class="text-brand-accent">— Yesterday?</span>
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-brand-gray-lighter md:mx-0">
            From first contact to final interview — we do the heavy lifting for free. You only invest once you are ready to grow.
          </p>
          <p class="mx-auto mt-4 max-w-2xl text-base text-brand-gray-light md:mx-0">
            BOSS BABE Enterprise Trading as BOSS Consult., specialises in facilitating connections between companies in search of extraordinary talent and candidates seeking the most appropriate career opportunities.
          </p>
          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row md:items-center">
            <a
              href="/employers/#consultationcall"
              class="inline-flex items-center border border-white bg-transparent px-8 py-3.5 text-base font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-white shadow-lg transition-all duration-300 hover:bg-white hover:text-brand-deep focus:outline-none focus:ring-2 focus:ring-brand-accent focus:ring-offset-2 focus:ring-offset-brand-hero"
            >
              Free Consultation
              <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>

        <div class="order-1 md:order-2 flex justify-center">
          <div class="relative">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-brand-accent/20 blur-xl"></div>
            <img src="/assets/logos/hero-image.webp" alt="BOSS Consult" class="relative rounded-2xl shadow-2xl" width="600" height="400" loading="eager">
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- WHY CHOOSE US + STATS (original: gradient section + counters) -->
  <section class="bg-gradient-to-br from-brand-hero to-brand-dark py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-white">
            Where excellence meets <span class="text-brand-accent">enthusiasm!</span>
          </h2>
          <p class="mt-4 text-lg font-semibold text-brand-accent">Why Choose Us?</p>
          <div class="mt-6 space-y-4 text-brand-gray-lighter">
            <p>We are not just recruiters — we are your growth partners. At <strong>BOSS Consult</strong>, we specialize in placing high-impact tech talent across Data Science, Development, and Design — and we do it with purpose.</p>
            <p>Founded on a passion for building community, our team brings a diverse mix of experience, empathy, and energy into every placement. We believe great recruiting is about more than filling a role — it is about creating real alignment between people and purpose.</p>
            <p>With no upfront fees, free screening and interviews, and flexible payment plans, we remove the risk from hiring — so you can focus on building the best team, faster.</p>
            <p class="text-base font-semibold text-brand-accent-light">Choosing us means choosing a recruitment partner who cares deeply about your success — and delivers on it.</p>
          </div>
        </div>

        <div class="flex flex-col justify-center">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
            <div class="rounded-xl bg-white/5 p-6 text-center backdrop-blur-sm">
              <div class="font-[family-name:var(--font-family-display)] text-4xl font-bold text-white sm:text-5xl">11<span class="text-brand-accent">K+</span></div>
              <p class="mt-2 text-sm text-brand-gray-lighter">Current Members</p>
            </div>
            <div class="rounded-xl bg-white/5 p-6 text-center backdrop-blur-sm">
              <div class="font-[family-name:var(--font-family-display)] text-4xl font-bold text-white sm:text-5xl">3<span class="text-brand-accent">K+</span></div>
              <p class="mt-2 text-sm text-brand-gray-lighter">Individuals Placed</p>
            </div>
            <div class="rounded-xl bg-white/5 p-6 text-center backdrop-blur-sm">
              <div class="font-[family-name:var(--font-family-display)] text-4xl font-bold text-white sm:text-5xl">8<span class="text-brand-accent">+</span></div>
              <p class="mt-2 text-sm text-brand-gray-lighter">Years Experience</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION & VISION SECTION (matching archive: "Striving for greatness" with image) -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <h2 class="text-brand-dark">Striving for greatness</h2>
      </div>
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div class="order-2 lg:order-1">
          <img src="/assets/Change-3_2.jpg" alt="Striving for greatness" class="w-full h-auto rounded-lg shadow-lg" loading="lazy">
        </div>
        <div class="order-1 lg:order-2 space-y-8">
          <div class="flex gap-4">
            <div class="flex-shrink-0 mt-1">
              <svg class="w-10 h-10 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
            <div>
              <h5 class="text-brand-accent uppercase tracking-[2px] mb-2">our Mission</h5>
              <p class="text-2xl font-bold text-brand-dark mb-3">To revolutionize the way great talent meets great companies.</p>
              <p class="text-brand-gray leading-relaxed">
                <strong>We exist to make hiring effortless</strong> — for both clients and candidates. With a deep bench of top-tier talent across tech, <strong>we simplify the recruitment process</strong> through <strong>hands-on consultation, 48-hour shortlists, and no upfront fees.</strong>
              </p>
              <p class="text-brand-gray leading-relaxed mt-3">
                Whether helping someone land their dream job or helping a startup scale fast, we're here to remove friction, build careers, and empower people to reach their potential.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 mt-1">
              <svg class="w-10 h-10 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h5 class="text-brand-accent uppercase tracking-[2px] mb-2">OUR VISION</h5>
              <p class="text-2xl font-bold text-brand-dark mb-3">A world where opportunity is accessible, and hiring is human, fast, and fair.</p>
              <p class="text-brand-gray leading-relaxed">
                At <strong>BOSS Consult</strong>, we envision a level playing field where people are seen for their skills, not just their CVs — and where companies can build high-performing teams without bureaucracy or bias.
              </p>
              <p class="text-brand-gray leading-relaxed mt-3">
                We believe productivity beats busyness — and we're here to streamline hiring, champion equity, and make every placement count.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CORE VALUES STRIP (matching archive: gradient bg, 8 values with icons) -->
  <div class="bg-gradient-to-r from-brand-hero to-brand-dark py-10 md:py-14">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-8">
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
          <span class="text-white text-sm font-semibold">Passion</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span class="text-white text-sm font-semibold">Care</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          <span class="text-white text-sm font-semibold">Integrity</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="text-white text-sm font-semibold">Transparency</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
          <span class="text-white text-sm font-semibold">Accountability</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          <span class="text-white text-sm font-semibold">Respect</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
          </svg>
          <span class="text-white text-sm font-semibold">Independence</span>
        </div>
        <div class="flex flex-col items-center text-center">
          <svg class="w-8 h-8 text-brand-accent-light mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
          </svg>
          <span class="text-white text-sm font-semibold">Courage</span>
        </div>
      </div>
    </div>
  </div>

  <!-- CLIENT LOGOS (original: light bg section) -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark">Trusted by Industry Leaders</h2>
        <p class="mt-3 text-lg text-brand-gray">Companies that rely on BOSS Consult for their talent needs</p>
      </div>

      <div class="mt-12 grid grid-cols-2 items-center gap-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        <div class="flex justify-center">
          <img src="/assets/logos/clothing-junction-logo.png" alt="Clothing Junction" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/african-ideas-logo.jpeg" alt="African Ideas" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/Victory-Lab-Logo.png" alt="Victory Lab" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/senqu-logo.webp" alt="Senqu" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/HumanInsights-Logo.jpeg" alt="HumanInsights" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/Hbook-Logo.png" alt="Hbook" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/goodwall_logo.jpeg" alt="Goodwall" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/EasyPay-Smaller-Logo.png" alt="EasyPay" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/CMS-Software-Solutions-Logo.jpeg" alt="CMS Software Solutions" class="max-h-10 sm:max-h-12 w-auto" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- OUR SUPPORT (matching archive: heading + 4 Artboard images) -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center mb-12">
        <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark">Our Support</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 items-center">
        <div class="flex justify-center">
          <img src="/assets/Artboard-1.jpg" alt="Support 1" class="w-full max-w-[504px] h-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/Artboard-1-copy.jpg" alt="Support 2" class="w-full max-w-[504px] h-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/Artboard-1-copy-2.jpg" alt="Support 3" class="w-full max-w-[504px] h-auto" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/Artboard-1-copy-3.jpg" alt="Support 4" class="w-full max-w-[504px] h-auto" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES EXPERTISE -->
  <section class="bg-brand-dark py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="font-[family-name:var(--font-family-display)] text-3xl font-bold text-white sm:text-4xl">Our <span class="text-brand-accent">Expertise</span></p>
        <p class="mt-3 text-lg text-brand-gray-light">Specialised recruitment across the tech spectrum</p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="rounded-2xl bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Data Science</h3>
          <ul class="mt-4 space-y-2 text-brand-gray-lighter">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Analytics</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Machine Learning</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Artificial Intelligence</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Big Data</li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Development</h3>
          <ul class="mt-4 space-y-2 text-brand-gray-lighter">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Full-stack</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Backend</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Frontend</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Mobile</li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.5m6 9V12m0 0V8m0 4v4m0-4h7.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Tech Talent</h3>
          <ul class="mt-4 space-y-2 text-brand-gray-lighter">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Engineering</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Infrastructure</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>DevOps</li>
          </ul>
        </div>
      </div>
    </div>
