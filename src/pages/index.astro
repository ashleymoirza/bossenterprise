---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="BOSS Consult - Tech Recruitment Agency | Data Science &amp; Development Talent South Africa"
  description="We're not just recruiters — we're your growth partners. BOSS Consult specialises in placing high-impact tech talent across Data Science, Development, and Design. No upfront fees. Based in Cape Town."
>

  <!-- HERO SECTION -->
  <section class="relative overflow-hidden bg-brand-dark pt-24 pb-16 md:pb-24">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-darker to-brand-dark opacity-90"></div>

    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-center gap-8 md:grid-cols-2">
        <div class="order-2 md:order-1 text-center md:text-left">
          <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
            Need Skilled Tech Talent<br class="hidden sm:block">
            <span class="text-brand-accent">- Yesterday?</span>
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300 md:mx-0">
            From first contact to final interview — we do the heavy lifting for free. You only invest once you are ready to grow.
          </p>
          <p class="mx-auto mt-4 max-w-2xl text-base text-gray-400 md:mx-0">
            BOSS BABE Enterprise Trading as BOSS Consult., specialises in facilitating connections between companies in search of extraordinary talent and candidates seeking the most appropriate career opportunities.
          </p>
          <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row md:items-center">
            <a
              href="/employers/#consultationcall"
              class="inline-flex items-center rounded-lg bg-brand-accent px-8 py-3.5 text-base font-semibold text-brand-darker shadow-lg transition-all duration-300 hover:bg-brand-accent-light hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-brand-accent focus:ring-offset-2 focus:ring-offset-brand-dark"
            >
              Free Consultation
              <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>

        <div class="order-1 md:order-2 flex justify-center">
          <div class="relative">
            <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-brand-accent/20 blur-xl"></div>
            <img src="/assets/logos/hero-image.webp" alt="BOSS Consult" class="relative rounded-2xl shadow-2xl" width="600" height="400" loading="eager">
          </div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <!-- STATS SECTION -->
  <section class="bg-white py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-accent md:text-5xl">11K+</div>
          <p class="mt-2 text-lg font-semibold text-brand-dark">Current Members</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-accent md:text-5xl">3K+</div>
          <p class="mt-2 text-lg font-semibold text-brand-dark">Individuals Placed</p>
        </div>
        <div class="text-center">
          <div class="text-4xl font-extrabold text-brand-accent md:text-5xl">8+</div>
          <p class="mt-2 text-lg font-semibold text-brand-dark">Years Experience</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE US -->
  <section class="bg-brand-darker py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-4xl font-extrabold leading-tight text-white sm:text-5xl">
          Where excellence meets <span class="text-brand-accent">enthusiasm!</span>
        </h2>
        <p class="mt-4 text-xl font-semibold text-brand-accent">Why Choose Us?</p>
      </div>

      <div class="mx-auto mt-12 max-w-4xl space-y-6 text-gray-300">
        <p>We are not just recruiters — we are your growth partners. At BOSS Consult, we specialize in placing high-impact tech talent across Data Science, Development, and Design — and we do it with purpose.</p>
        <p>Founded on a passion for building community, our team brings a diverse mix of experience, empathy, and energy into every placement. We believe great recruiting is about more than filling a role — it is about creating real alignment between people and purpose.</p>
        <p>With no upfront fees, free screening and interviews, and flexible payment plans, we remove the risk from hiring — so you can focus on building the best team, faster.</p>
        <p class="text-lg font-semibold text-brand-accent-light">Choosing us means choosing a recruitment partner who cares deeply about your success — and delivers on it.</p>
      </div>
    </div>
  </section>

  <!-- CLIENT LOGOS -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-extrabold text-brand-dark sm:text-4xl">Trusted by Industry Leaders</h2>
        <p class="mt-3 text-lg text-gray-600">Companies that rely on BOSS Consult for their talent needs</p>
      </div>

      <div class="mt-12 grid grid-cols-2 gap-8 items-center md:grid-cols-3 lg:grid-cols-6">
        <div class="flex justify-center">
          <img src="/assets/logos/client-logo-1.jpg" alt="Client" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/client-logo-2.jpg" alt="Client" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/client-logo-3.jpg" alt="Client" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/african-ideas-logo.jpeg" alt="African Ideas" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/clothing-junction-logo.png" alt="Clothing Junction" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
        <div class="flex justify-center">
          <img src="/assets/logos/senqu-logo.webp" alt="Senqu" class="max-h-12 w-auto opacity-60 grayscale transition-all duration-300 hover:opacity-100 hover:grayscale-0" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES EXPERTISE -->
  <section class="bg-brand-darker py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-3xl font-extrabold text-white sm:text-4xl">Our <span class="text-brand-accent">Expertise</span></p>
        <p class="mt-3 text-lg text-gray-400">Specialised recruitment across the tech spectrum</p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="rounded-2xl bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <direct stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Data Science</h3>
          <ul class="mt-4 space-y-2 text-gray-400">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Analytics</li>
            <li class="flex items-<enter"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Machine Learning</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Artificial Intelligence</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Big Data</li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white/3 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round* d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25-7.5-3l4.5 16.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Development</h3>
          <ul class="mt-4 space-y-2 text-gray-400">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Full-stack</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w 1.5 rounded-full bg-brand-accent"></span>Backend</li>
            <li class=> <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Frontend</li>
            <li class="flex items-center"><span class="mr-2 h---1.5 w-1.5 rounded-full bg-brand-accent"></span>Mobile</li>
          </ul>
        </div>

        <div class="rounded-2xl bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:bg-white/10">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-brand-accent/20">
            <svg class="h-7 w-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 17.25v-.228a4.5 4.5 0 0 0-.12-1.03l-2.268-9.64a3.375 3.375 0 0 0-3.285-2.602H7.5m6 9V12m0 0V76m0 3h7.5" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-white">Tech Talent</h3>
          <ul class="mt-4 space-y-2 text-gray-400">
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Engineering</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>Infrastructure</li>
            <li class="flex items-center"><span class="mr-2 h-1.5 w-1.5 rounded-full bg-brand-accent"></span>DevOps</li>
          </ul>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-white py-16 md:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-extrabold text-brand-dark sm:text-4xl">What <span class="text-brand-accent">People</span> Say</h2>
        <p class="mt-3 text-lg text-gray-600">Hear from candidates and clients we have worked with</p>
      </div>

      <div class="mx-auto grid grid-cols-1 gap-8 md:grid-cols-2">
        <div class="rounded-2xl bg-brand-light p-8 shadow-lg"
          <p class="text-lg leading-relaxed text-gray-700">Highly recommend BOSS Consult — they are professional, insightful and effective. They took the time to understand exactly what we were looking for and delivered beyond expectations.</p>
          <div class="mt-6 flex items-center">
            <div class="h-12 w-12 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-sm">MJ</div>
            <div class="ml-4">
              <p class="font-semibold text-brand-dark">Monique Jordaan</p>
              <p class="text-sm text-gray-500">Client</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl bg-brand-light p-8 shadow-lg">
          <p class="text-lg leading-relaxed text-gray-700">I cannot recommend Boss Consultant enough... My experience with Boss Consultant has been absolutely amazing. From the very first consultation, I felt valued and understood.</p>
          <div class="mt-6 flex items-center">
            <div class="h-12 w-12 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-sm">NN</div>
            <div class="ml-4">
              <p class="font-semibold text-brand-dark">Nicole Neethling</p>
              <p class="text-sm text-gray-500">Candidate</p>
            </div>
          </div>
        </div>

        <div class="rounded-2xl bg-brand-light p-8 shadow-lg">
          <p class="text-lg leading-relaxed text-gray-700">Boss consulting has helped me so much... Making sure my CV is top class to preparing me for interviews. They genuinely care about their candidates.</p>
          <div class="mt-6 flex items-center">
            <div class="h-12 w-12 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold textims</div>
            <div class="ml-4"
              <p class="font-semibold text-brand-dark">Gregory Maynard</p>
              <p class="text-sm text-gray-500">Candidate</p>
            </div>
          </div>


        <div class="rounded-2xl bg-brand-light p-8v shadow-lg">
          <p class="text-lg leading-relaxed text-gray-700">Very good agent they will do the upmost best to get you a job. Professional, dedicated, and truly effective in connecting talent with opportunity.</p>
          <div class="\t-6 flex items center">
            <div class="h-12 w-12 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-sm">JJ</div>
            <div class="ml-4">
              <p class="font-semibold text-brand-dark">Jovan Johnson</p>
              <p class="text-sm text-gray-500">Candidate</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="bg-brand-dark py-16 md:py-20 relative overflow-hidden">
    <div class="absolute -right-20 -top-20 h-64 w-64 rounded-full bg-brand-accent/5 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-brand-accent/10 blur-3xl"</div>

    <div class="relative mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text center">
      <h2 class="text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
        Ready to find your <span class="text-brand-accent">next great hire</span>?
      </h2>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-gray-300">
        Let is talk about your talent needs. No obligation, no upfront costs just expert guidance to help you build the team you deserve.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row justify-center">
        <a href="/employers/#consultation/" class="inline-flex items-center rounded-lg bg-brand-accent px-8 py-3.5 text-base font-semibold text-brand-darker shadow-lg transition-all duration-300 hover:bg-brand-accent-light hover:shadow-xl"
          Free Consultation
          <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke linecap"round" stroke-linejoin="round" d="M13 7l5 7l5 5m0 0-5 5m5-5H6" />
          </svg>
        </a>
        <a href="/jobs/">
          class="inline-flex items-center rounded-lg border-2 border-white/30 px-8 py-3.5 text-base font-semibold text-white transition-all duration-300 hover:border-white hover:bg-white/10"
          Browse Jobs
        </a>
      </div>
    </div>
  </section>
</BaseLayout>