---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Employers - BOSS Consult | Tech Recruitment Solutions"
  description="Need skilled tech talent? BOSS Consult offers no-engagement fees, free screening, and flexible payment plans. We specialise in Data Science, Development, and Big Data talent."
>
  <main class="pt-24">
    <!-- Hero Section -->
    <section class="bg-brand-dark text-white py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-white mb-6">Need Skilled Tech Talent &mdash; Yesterday?</h1>
        <p class="text-lg lg:text-xl text-brand-gray-lighter max-w-3xl mx-auto leading-relaxed">
          We do the heavy lifting so you don&rsquo;t have to. From sourcing and screening to the final shortlist &mdash; we find the right people, on your terms, without the upfront costs.
        </p>
        <a href="#consultationcall" class="inline-flex items-center border border-white bg-transparent px-8 py-3 font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-white hover:bg-white hover:text-brand-deep transition-colors text-lg mt-8">
          Book a Free Consultation
        </a>
      </div>
    </section>

    <!-- Value Props Section -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-brand-light rounded-xl p-8 text-center shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-3">No Upfront Fees</h3>
            <p class="text-brand-gray leading-relaxed">
              You don&rsquo;t pay a cent until we deliver. Our success-based model means we&rsquo;re fully invested in finding you the right hire.
            </p>
          </div>

          <div class="bg-brand-light rounded-xl p-8 text-center shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-3">Free Screening &amp; Interviews</h3>
            <p class="text-brand-gray leading-relaxed">
              We pre-vet every candidate so you only meet the best. Technical assessments, culture fit checks &mdash; all handled at no cost to you.
            </p>
          </div>

          <div class="bg-brand-light rounded-xl p-8 text-center shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-full flex items-center justify-center mx-auto mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-3">Flexible Payment Plans</h3>
            <p class="text-brand-gray leading-relaxed">
              Hire now, pay later. We offer payment terms that work with your cash flow &mdash; no pressure, no hidden fees.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services / Specializations Section -->
    <section class="py-20 bg-brand-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark text-center mb-4">What We Cover</h2>
        <p class="text-brand-gray text-center text-lg mb-12 max-w-2xl mx-auto">
          We specialise in sourcing high-impact tech talent across the full spectrum of roles.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="bg-white rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-4">Data Science</h3>
            <ul class="space-y-2 text-brand-gray">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Analytics &amp; BI
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Machine Learning
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Artificial Intelligence
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Big Data &amp; Engineering
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-4">Development</h3>
            <ul class="space-y-2 text-brand-gray">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Full-Stack Development
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Backend Engineering
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Frontend &amp; Mobile
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Cloud &amp; DevOps
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-14 h-14 bg-brand-accent/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-7 h-7 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 016 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-dark mb-4">Tech Talent</h3>
            <ul class="space-y-2 text-brand-gray">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Engineering Management
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Infrastructure &amp; SRE
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                Security &amp; Compliance
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-brand-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                IT Leadership &amp; CTO
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-brand-dark">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-white mb-4">Ready to Scale Your Tech Team?</h2>
        <p class="text-brand-gray-lighter text-lg mb-8">
          Stop spending weeks on hiring. Let us find you the right talent &mdash; fast, free, and flexible.
        </p>
        <a href="/contact" class="inline-flex items-center border border-white bg-transparent px-8 py-3 font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-white hover:bg-white hover:text-brand-deep transition-colors text-lg">Get in Touch</a>
      </div>
    </section>

    <!-- Consultation Booking Section -->
    <section id="consultationcall" class="py-20 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark text-center mb-4">Let&rsquo;s Find Your Next Hire</h2>
        <p class="text-brand-gray text-center text-lg mb-12 max-w-2xl mx-auto">
          Tell us about the role you need to fill and we&rsquo;ll get back to you within 24 hours with a shortlist.
        </p>
        <form method="POST" action="/php/contact.php" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-brand-dark mb-1">Your Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-brand-gray-lighter rounded-lg focus:ring-2 focus:ring-brand-accent focus:border-brand-accent outline-none transition-colors" placeholder="John Doe" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-brand-dark mb-1">Company Name</label>
              <input type="text" id="company" name="company" required class="w-full px-4 py-3 border border-brand-gray-lighter rounded-lg focus:ring-2 focus:ring-brand-accent focus:border-brand-accent outline-none transition-colors" placeholder="Acme Corp" />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="email" class="block text-sm font-medium text-brand-dark mb-1">Email Address</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-brand-gray-lighter rounded-lg focus:ring-2 focus:ring-brand-accent focus:border-brand-accent outline-none transition-colors" placeholder="john@acmecorp.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-brand-dark mb-1">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 border border-brand-gray-lighter rounded-lg focus:ring-2 focus:ring-brand-accent focus:border-brand-accent outline-none transition-colors" placeholder="+27 63 240 4447" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-brand-dark mb-1">Tell Us About Your Role</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-brand-gray-lighter rounded-lg focus:ring-2 focus:ring-brand-accent focus:border-brand-accent outline-none transition-colors resize-vertical" placeholder="Describe the role, required skills, experience level, and any other details..."></textarea>
          </div>
          <div class="text-center">
            <button type="submit" class="inline-flex items-center border border-brand-dark bg-transparent px-8 py-3 font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-brand-dark hover:bg-brand-dark hover:text-white transition-colors text-lg cursor-pointer">
              Submit Enquiry
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>