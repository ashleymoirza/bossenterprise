---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About BOSS Consult - Tech Recruitment Agency in Cape Town"
  description="Learn about BOSS Consult - your growth partners in tech recruitment. We specialise in connecting top tech talent with leading employers across Data Science, Development, and more."
>
  <main class="pt-24">
    <!-- Hero Section -->
    <section class="bg-brand-dark text-white py-20 lg:py-28">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-white mb-6">About BOSS Consult</h1>
        <p class="text-lg lg:text-xl text-brand-gray-lighter max-w-3xl mx-auto leading-relaxed">
          We are a dedicated recruitment agency specialising in connecting high-impact tech talent with leading companies. We are deeply invested in creating a positive impact on the world by finding the right people for the right roles.
        </p>
      </div>
    </section>

    <!-- Mission and Vision -->
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <div>
            <h2 class="text-brand-accent mb-4">Our Mission</h2>
            <p class="text-brand-gray leading-relaxed">
              To bridge the gap between exceptional talent and forward-thinking organisations. We strive to make recruitment a seamless, transparent, and empowering experience for both candidates and employers with no upfront fees, free screening, and flexible payment plans that put people first.
            </p>
          </div>
          <div>
            <h2 class="text-brand-accent mb-4">Our Vision</h2>
            <p class="text-brand-gray leading-relaxed">
              To be the most trusted recruitment partner in South Africa, known for our commitment to quality, integrity, and genuine care for the people we work with. We envision a world where every talented professional finds their ideal role and every company builds the team they need to thrive.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-20 bg-brand-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="p-8">
            <div class="font-[family-name:var(--font-family-display)] text-4xl lg:text-5xl font-bold text-brand-accent mb-2">11K+</div>
            <p class="text-brand-gray-lighter text-lg">Community Members</p>
          </div>
          <div class="p-8">
            <div class="font-[family-name:var(--font-family-display)] text-4xl lg:text-5xl font-bold text-brand-accent mb-2">3K+</div>
            <p class="text-brand-gray-lighter text-lg">Talent Placed</p>
          </div>
          <div class="p-8">
            <div class="font-[family-name:var(--font-family-display)] text-4xl lg:text-5xl font-bold text-brand-accent mb-2">8+</div>
            <p class="text-brand-gray-lighter text-lg">Years of Experience</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Core Values -->
    <section class="py-20 bg-brand-light">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-[family-name:var(--font-family-heading)] text-brand-dark text-center mb-12">Our Core Values</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-brand-dark mb-2">Community</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              We believe in the power of connections. Building a strong, supportive community of professionals and organisations is at the heart of everything we do.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-brand-dark mb-2">Empathy</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              We listen, we understand, we care. Every candidate and client is treated with genuine compassion and respect throughout their journey with us.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-brand-dark mb-2">Excellence</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              We set high standards and deliver exceptional results. From candidate screening to client matching, mediocrity is never an option.
            </p>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow">
            <div class="w-12 h-12 bg-brand-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-brand-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-brand-dark mb-2">Partnership</h3>
            <p class="text-brand-gray text-sm leading-relaxed">
              We don't just fill positions — we build lasting relationships. Long-term success comes from true partnership with both talent and employers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-brand-dark">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-white mb-4">Ready to Work With Us?</h2>
        <p class="text-brand-gray-lighter text-lg mb-8">
          Looking for top talent or your next career opportunity, we are your growth partners. Let us find the perfect fit for your team or your career.
        </p>
        <a href="/contact" class="inline-flex items-center border border-white bg-transparent px-8 py-3 font-[family-name:var(--font-family-accent)] uppercase tracking-[5.2px] text-white hover:bg-white hover:text-brand-deep transition-colors text-lg">Get in Touch</a>
      </div>
    </section>
  </main>
</BaseLayout>